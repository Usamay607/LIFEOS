# Data mode: mock (default) or notion
LOS_DATA_MODE=mock

# Locale defaults
LOS_TIMEZONE=Australia/Melbourne
LOS_LOCALE=en-AU
LOS_CURRENCY=AUD

# Optional dashboard gate
LOS_DASHBOARD_PIN=

# Optional: enable service worker in local dev (`pnpm dev`) for PWA testing
NEXT_PUBLIC_ENABLE_PWA_DEV=false

# Notion integration
NOTION_TOKEN=
NOTION_DATABASE_AREAS_ID=
NOTION_DATABASE_ENTITIES_ID=
NOTION_DATABASE_PROJECTS_ID=
NOTION_DATABASE_TASKS_ID=
NOTION_DATABASE_PATHWAYS_ID=
NOTION_DATABASE_COURSES_CERTS_ID=
NOTION_DATABASE_ACCOUNTS_ID=
NOTION_DATABASE_TRANSACTIONS_ID=
NOTION_DATABASE_UPCOMING_EXPENSES_ID=
NOTION_DATABASE_METRICS_ID=
NOTION_DATABASE_HEALTH_LOGS_ID=
NOTION_DATABASE_WORKOUTS_ID=
NOTION_DATABASE_FAMILY_EVENTS_ID=
NOTION_DATABASE_RELATIONSHIP_CHECKINS_ID=
NOTION_DATABASE_TIME_OFF_PLANS_ID=
NOTION_DATABASE_JOURNAL_ENTRIES_ID=
NOTION_DATABASE_REVIEWS_ID=

# Optional AI summary provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
